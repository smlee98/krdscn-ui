{
  "$schema": "https://json.schemastore.org/prettierrc.json",
  "singleQuote": false,
  "printWidth": 120,
  "semi": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false,
  "endOfLine": "lf",
  "plugins": ["prettier-plugin-tailwindcss", "prettier-plugin-sh"],
  "proseWrap": "never"
}
